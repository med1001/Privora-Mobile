# Backend host for HTTP + WebSocket (port 8000). Set in .env — see app.config.js.
# Emulator: omit or EXPO_PUBLIC_API_HOST=10.0.2.2
# Real phone (same Wi‑Fi as PC): EXPO_PUBLIC_API_HOST=192.168.x.x  (PC IPv4 from ipconfig)
# Real phone + USB: EXPO_PUBLIC_API_HOST=127.0.0.1  then: adb reverse tcp:8000 tcp:8000
