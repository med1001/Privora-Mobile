# Copy to `.env` for Firebase web API key (see README / firebase setup).
# Copy backend overrides to `.env.local` (recommended, gitignored) so production stays default.

# --- Firebase (required for auth; values also partially in app.json extra) ---
# EXPO_PUBLIC_FIREBASE_API_KEY=

# --- Backend: omit everything below to use production https://privora-app.com ---

# Single override (recommended for local dev):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000

# Or compose from host + port (HTTP, dev):
# EXPO_PUBLIC_API_HOST=192.168.1.10
# EXPO_PUBLIC_API_PORT=8000
# EXPO_PUBLIC_API_USE_TLS=false

# Production on a non-default host:
# EXPO_PUBLIC_API_BASE_URL=https://api.example.com
