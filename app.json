{
  "expo": {
    "name": "Privora-Mobile",
    "slug": "Privora-Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Privora uses the microphone for voice calls and voice messages.",
        "NSCameraUsageDescription": "Privora uses the camera so you can send photos in your conversations.",
        "NSPhotoLibraryUsageDescription": "Privora needs photo library access to send images in your conversations.",
        "NSPhotoLibraryAddUsageDescription": "Privora can save received images to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CHANGE_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.FOREGROUND_SERVICE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.PrivoraMobile",
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "registerUrl": "https://privora-61d4d.firebaseapp.com/register",
      "firebaseAuthDomain": "privora-61d4d.firebaseapp.com",
      "firebaseProjectId": "privora-61d4d",
      "firebaseStorageBucket": "privora-61d4d.firebasestorage.app",
      "firebaseMessagingSenderId": "118761355969",
      "firebaseAppId": "1:118761355969:web:210c4c457d7a0ed73e3240"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Privora needs photo library access to send images.",
          "cameraPermission": "Privora needs camera access to take and send pictures."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2563eb",
          "sounds": ["./assets/sounds/ringing.mp3"]
        }
      ]
    ]
  }
}
